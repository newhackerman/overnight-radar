APP_NAME=Overnight Radar
APP_ENV=development
DEBUG=false
# IMPORTANT: Must change in production, app will refuse to start with default value
SECRET_KEY=change-this-secret
ADMIN_USERNAME=admin
# Generate with: python -m app.web.auth --hash-password your-password
ADMIN_PASSWORD_HASH=

# Database (Docker部署时使用 host.docker.internal 连接宿主机MySQL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=overnight_radar
MYSQL_PASSWORD=change-this-password
MYSQL_DATABASE=overnight_radar

# AI Analysis
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=claude-sonnet-4-6
AI_TEMPERATURE=0.2
AI_TIMEOUT_SECONDS=90

# Push Channel
WECOM_WEBHOOK=
WECOM_MAX_BYTES=4096

# Scheduler (CST timezone)
DAILY_JOB_TIME=06:00
DAILY_PUSH_TIME=08:00

# Data Fetching
REQUEST_TIMEOUT_SECONDS=15
YFINANCE_PERIOD=15d

# Report
# Override default US symbols list with JSON array, e.g. '["NVDA","TSLA","AAPL"]'
US_SYMBOLS_JSON=
TOP_TURNOVER_LIMIT=50
REPORT_MAX_ITEMS=20

# Backtest
MAX_BACKTEST_DAYS=3650
BACKTEST_HISTORY_DAYS=30

# Session Security
SESSION_MAX_AGE_SECONDS=604800
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
